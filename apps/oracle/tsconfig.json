{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "lib": ["es2021"],
    "incremental": true,
    "skipLibCheck": true,
    "paths": {
      "@gitlancer/db": ["../../packages/database/index.ts"]
    }
  },
  "include": ["src/**/*"] 
}