generator client {
  provider     = "prisma-client"
  output       = "../generated" 
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}


model User {
  id            String         @id 
  githubHandle  String         @unique
  avatarUrl     String?        
  solanaWallet  String?        @unique
  
  contributions Contribution[]
  vaults        Vault[]        
  
  createdAt     DateTime       @default(now())
}

model Vault {
  id                 String   @id @default(uuid())
  repositoryFullName String   @unique 
  pdaAddress         String   @unique 
  vaultBump          Int      
  budgetLimit        Float    @default(100.0) 
  discordWebhookUrl  String?  
  
  maintainerId       String
  maintainer         User     @relation(fields: [maintainerId], references: [id])
  
  contributions      Contribution[]
  createdAt          DateTime @default(now())
}

enum ContributionStatus {
  PENDING_APPROVAL
  AUDITED
  CLAIMED
  REJECTED 
}

model Contribution {
  id        String             @id @default(uuid())
  prId      String
  amount    Float
  status    ContributionStatus 
  
  userId    String
  user      User               @relation(fields: [userId], references: [id])
  
  vaultId   String?
  vault     Vault?             @relation(fields: [vaultId], references: [id])
  
  createdAt DateTime           @default(now())
}